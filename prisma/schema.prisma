// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id    String  @id @default(uuid())
  email String  @unique
  name  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinics       Clinic[]
  ClinicUser    ClinicUser[]
  emailVerified Boolean
  image         String?
  sessions      Session[]
  accounts      Account[]

  @@map("user")
}

model Clinic {
  id   String @id @default(uuid())
  name String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Appointment Appointment[]
  Doctor      Doctor[]

  users      User[]
  ClinicUser ClinicUser[]
  Patient    Patient[]

  @@map("clinic")
}

model ClinicUser {
  clinicId String
  userId   String

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([clinicId, userId], map: "clinic_user_pkey")
  @@map("clinic_user")
}

model Doctor {
  id                   String  @id @default(uuid())
  name                 String
  avatar               String?
  specialty            String?
  availableFromWeekday Int
  availableToWeekday   Int
  availableFromTime    String
  availableToTime      String
  appointPriceInCents  Int
  clinicId             String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic      Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  Appointment Appointment[]

  @@map("doctor")
}

model Patient {
  id          String        @id @default(uuid())
  name        String
  phoneNumber String
  email       String        @unique
  sex         pacienSexEnum
  clinicId    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Appointment Appointment[]
  clinic      Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("patient")
}

enum pacienSexEnum {
  MALE
  FEMALE
}

model Appointment {
  id           String   @id @default(uuid())
  patientId    String
  doctorId     String
  clinicId     String
  date         DateTime
  priceInCents Int

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  clinic  Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("appointment")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}
